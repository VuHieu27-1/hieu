{
  "server": {
    "port": 3000
  },
  "storage": {
    "databaseFile": "./data/bookings.db",
    "logDir": "./data/logs"
  },
  "dispatch": {
    "baseUrl": "https://your-dispatch-server.example.com"
  },
  "geocoding": {
    "provider": "mapbox",
    "language": "vi",
    "country": "vn",
    "reverseGeocodeUrl": "https://nominatim.openstreetmap.org/reverse",
    "searchGeocodeUrl": "https://nominatim.openstreetmap.org/search",
    "mapbox": {
      "accessToken": "pk.your_mapbox_public_or_server_token",
      "forwardGeocodeUrl": "https://api.mapbox.com/search/geocode/v6/forward",
      "reverseGeocodeUrl": "https://api.mapbox.com/search/geocode/v6/reverse",
      "types": "address,street,locality,neighborhood,place"
    }
  },
  "http": {
    "locationTimeoutMs": null,
    "dispatchTimeoutMs": null
  },
  "booking": {
    "maxPendingBookings": 200,
    "idempotencyTtlMs": 600000
  }
}
